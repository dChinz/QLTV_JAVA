<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.CategoryController"
      spacing="20" styleClass="content-area">

    <!-- Left: Table -->
    <VBox HBox.hgrow="ALWAYS" spacing="12">
        <HBox spacing="12" alignment="CENTER_LEFT">
            <TextField fx:id="searchField" promptText="Tìm danh mục..."
                       styleClass="search-field" HBox.hgrow="ALWAYS"/>
        </HBox>

        <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS" onMouseClicked="#handleTableClick">
            <columns>
                <TableColumn fx:id="colSelect" text="" prefWidth="36"/>
                <TableColumn fx:id="colSTT"    text="STT"         prefWidth="50"/>
                <TableColumn fx:id="colName"   text="Tên danh mục" prefWidth="200"/>
                <TableColumn fx:id="colBooks"  text="Số sách"    prefWidth="70"/>
                <TableColumn fx:id="colDesc"   text="Mô tả"      prefWidth="220"/>
                <TableColumn fx:id="colCatActions" text=""      prefWidth="80"/>
            </columns>
            <placeholder><Label text="Chưa có danh mục nào"/></placeholder>
        </TableView>

        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
            <Button text="Xóa đã chọn" styleClass="btn-danger" onAction="#handleBulkDelete"
                    style="-fx-font-size:11px; -fx-padding:5 12 5 12;"/>
        </HBox>
    </VBox>

    <!-- Right: Form -->
    <VBox styleClass="card" minWidth="300" maxWidth="340" spacing="16">
        <Label fx:id="formTitle" text="Thêm danh mục mới" styleClass="section-header"/>
        <Separator/>

        <VBox spacing="6">
            <Label text="Tên danh mục *" styleClass="form-label"/>
            <TextField fx:id="nameField" promptText="Nhập tên danh mục" styleClass="text-field" maxWidth="Infinity"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Mô tả" styleClass="form-label"/>
            <TextArea fx:id="descField" promptText="Nhập mô tả (tùy chọn)"
                      prefRowCount="4" wrapText="true" styleClass="text-field" maxWidth="Infinity"/>
        </VBox>

        <HBox spacing="8">
            <Button fx:id="saveButton" text="Lưu" styleClass="btn-primary" onAction="#handleSave"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <Button text="Làm mới" styleClass="btn-outline" onAction="#handleClear"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <Button fx:id="deleteButton" text="Xóa danh mục này" styleClass="btn-danger"
                maxWidth="Infinity" visible="false" managed="false" onAction="#handleDelete"/>

        <Label fx:id="formMessage" text="" wrapText="true" style="-fx-font-size: 12px;"/>
    </VBox>

</HBox>
