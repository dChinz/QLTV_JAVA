<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.BorrowController"
      spacing="16" styleClass="content-area">

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Tìm theo tên đọc giả, tên sách..."
                   styleClass="search-field" HBox.hgrow="ALWAYS" onAction="#handleSearch"/>
        <ComboBox fx:id="statusFilter" promptText="Tất cả trạng thái" prefWidth="180"
                  onAction="#handleSearch"/>
        <Button text="Tìm kiếm" styleClass="btn-primary" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Mượn sách mới" styleClass="btn-success" onAction="#handleNewBorrow"/>
        <Button text="Đồng bộ quá hạn" styleClass="btn-warning" onAction="#handleSyncOverdue"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="borrowTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId"         text="ID"            prefWidth="50"/>
            <TableColumn fx:id="colMember"     text="Đọc giả"       prefWidth="180"/>
            <TableColumn fx:id="colBook"       text="Sách"          prefWidth="220"/>
            <TableColumn fx:id="colBorrowDate" text="Ngày mượn"     prefWidth="100"/>
            <TableColumn fx:id="colDueDate"    text="Hạn trả"       prefWidth="100"/>
            <TableColumn fx:id="colReturnDate" text="Ngày trả"      prefWidth="100"/>
            <TableColumn fx:id="colStatus"     text="Trạng thái"    prefWidth="110"/>
            <TableColumn fx:id="colActions"    text="Thao tác"      prefWidth="180"/>
        </columns>
        <placeholder><Label text="Không có phiếu mượn nào"/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
</VBox>
