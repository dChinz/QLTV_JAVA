<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.controller.ReportController"
            fitToWidth="true" fitToHeight="true"
            styleClass="content-area">

    <VBox spacing="24" style="-fx-padding: 8 0 0 0;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <Label text="Báo cáo &amp; Thống kê" styleClass="section-header" HBox.hgrow="ALWAYS"/>
            <Label text="Năm:" style="-fx-text-fill: #64748B; -fx-font-size: 13px;"/>
            <ComboBox fx:id="yearCombo" prefWidth="106"/>
            <Button text="Làm mới" styleClass="btn-outline" onAction="#refresh"/>
        </HBox>

        <!-- KPI Summary Cards -->
        <HBox spacing="16">
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label fx:id="lblYearBorrows" styleClass="stat-card-value" text="—"/>
                <Label text="Lượt mượn năm nay" styleClass="stat-card-label"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label fx:id="lblTotalBooks" styleClass="stat-card-value" text="—"/>
                <Label text="Tổng số sách" styleClass="stat-card-label"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label fx:id="lblActiveMembers" styleClass="stat-card-value" text="—"/>
                <Label text="Thành viên hoạt động" styleClass="stat-card-label"/>
            </VBox>
            <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label fx:id="lblOverdue" styleClass="stat-card-value" text="—" style="-fx-text-fill: #E11D48;"/>
                <Label text="Đang quá hạn" styleClass="stat-card-label"/>
            </VBox>
        </HBox>

        <!-- Monthly BarChart -->
        <VBox styleClass="card" spacing="12">
            <Label text="Lượt mượn theo tháng" styleClass="section-header"/>
            <Separator/>
            <BarChart fx:id="monthlyChart" prefHeight="280"
                      legendVisible="false" animated="true"
                      barGap="3" categoryGap="14">
                <xAxis>
                    <CategoryAxis fx:id="monthlyXAxis" side="BOTTOM"/>
                </xAxis>
                <yAxis>
                    <NumberAxis fx:id="monthlyYAxis" side="LEFT"
                                label="Lượt mượn" minorTickCount="4"/>
                </yAxis>
            </BarChart>
        </VBox>

        <!-- Top Books + Category side by side -->
        <HBox spacing="16">

            <!-- Top Borrowed Books -->
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
                <Label text="Top 10 sách mượn nhiều nhất" styleClass="section-header"/>
                <Separator/>
                <TableView fx:id="topBooksTable" prefHeight="320">
                    <columns>
                        <TableColumn fx:id="colBRank"   text="#"          prefWidth="36"/>
                        <TableColumn fx:id="colBTitle"  text="Tên sách"   prefWidth="190"/>
                        <TableColumn fx:id="colBAuthor" text="Tác giả"    prefWidth="120"/>
                        <TableColumn fx:id="colBCount"  text="Lượt"       prefWidth="60"/>
                        <TableColumn fx:id="colBBar"    text="Tỉ lệ"      prefWidth="110"/>
                    </columns>
                    <placeholder><Label text="Chưa có dữ liệu"/></placeholder>
                </TableView>
            </VBox>

            <!-- Books by Category -->
            <VBox styleClass="card" HBox.hgrow="ALWAYS" spacing="12">
                <Label text="Phân bổ sách theo danh mục" styleClass="section-header"/>
                <Separator/>
                <TableView fx:id="categoryTable" prefHeight="320">
                    <columns>
                        <TableColumn fx:id="colCatName"  text="Danh mục"  prefWidth="160"/>
                        <TableColumn fx:id="colCatCount" text="Số sách"   prefWidth="70"/>
                        <TableColumn fx:id="colCatBar"   text="Tỉ lệ"    prefWidth="160"/>
                    </columns>
                    <placeholder><Label text="Chưa có dữ liệu"/></placeholder>
                </TableView>
            </VBox>

        </HBox>

        <!-- Top Active Members -->
        <VBox styleClass="card" spacing="12">
            <Label text="Top 10 đọc giả tích cực nhất" styleClass="section-header"/>
            <Separator/>
            <TableView fx:id="topMembersTable" prefHeight="280">
                <columns>
                    <TableColumn fx:id="colMRank"  text="#"         prefWidth="36"/>
                    <TableColumn fx:id="colMCode"  text="Mã TV"     prefWidth="90"/>
                    <TableColumn fx:id="colMName"  text="Họ tên"    prefWidth="220"/>
                    <TableColumn fx:id="colMCount" text="Lượt"      prefWidth="60"/>
                    <TableColumn fx:id="colMBar"   text="Tỉ lệ"    prefWidth="220"/>
                </columns>
                <placeholder><Label text="Chưa có dữ liệu"/></placeholder>
            </TableView>
        </VBox>

    </VBox>
</ScrollPane>
