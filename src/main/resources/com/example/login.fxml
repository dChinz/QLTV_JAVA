<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.controller.LoginController"
           styleClass="login-root"
           stylesheets="@styles/main.css">

    <VBox alignment="CENTER" spacing="0">
        <!-- Login Card -->
        <VBox styleClass="login-card" alignment="TOP_CENTER" spacing="0" maxWidth="400" minWidth="380">

            <VBox alignment="CENTER" spacing="8">
                <Label styleClass="login-title" text="Thư viện"/>
                <Label styleClass="login-subtitle" text="Hệ thống quản lý thư viện"/>
            </VBox>

            <Region minHeight="32"/>

            <!-- Error Message -->
            <Label fx:id="errorLabel" styleClass="badge-danger" wrapText="true"
                   maxWidth="Infinity" alignment="CENTER" visible="false" managed="false"/>
            <Region fx:id="errorSpacer" minHeight="12" visible="false" managed="false"/>

            <!-- Username -->
            <VBox spacing="6">
                <Label styleClass="form-label" text="Tên đăng nhập"/>
                <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập"
                           styleClass="text-field" maxWidth="Infinity"
                           onAction="#handleLogin"/>
            </VBox>

            <Region minHeight="16"/>

            <!-- Password -->
            <VBox spacing="6">
                <Label styleClass="form-label" text="Mật khẩu"/>
                <HBox fx:id="passwordWrapper" styleClass="password-wrapper" alignment="CENTER_LEFT">
                    <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu"
                                   styleClass="password-field-inner" HBox.hgrow="ALWAYS"
                                   onAction="#handleLogin"/>
                    <TextField fx:id="passwordVisible" promptText="Nhập mật khẩu"
                               styleClass="password-field-inner" HBox.hgrow="ALWAYS"
                               visible="false" managed="false"
                               onAction="#handleLogin"/>
                    <Button fx:id="togglePasswordBtn" styleClass="password-toggle-btn"
                            onAction="#togglePassword"/>
                </HBox>
            </VBox>

            <Region minHeight="28"/>

            <!-- Login Button -->
            <Button fx:id="loginButton" text="Đăng Nhập" styleClass="btn-primary"
                    maxWidth="Infinity" minHeight="42" onAction="#handleLogin"/>

            <Region minHeight="20"/>

            <!-- Footer hint -->
            <Label text="Mặc định: admin / Admin@123" styleClass="login-subtitle" alignment="CENTER"/>

        </VBox>
    </VBox>

</StackPane>
