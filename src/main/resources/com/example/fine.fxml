<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.FineController"
      spacing="16" styleClass="content-area">

    <!-- Summary Bar -->
    <HBox spacing="16">
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="Tổng phí phạt chưa thu" styleClass="stat-card-label"/>
            <Label fx:id="totalUnpaidLabel" text="0đ" styleClass="stat-card-value" style="-fx-text-fill: #DC2626;"/>
        </VBox>
        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="6">
            <Label text="Số phiếu chưa thanh toán" styleClass="stat-card-label"/>
            <Label fx:id="unpaidCountLabel" text="0" styleClass="stat-card-value"/>
        </VBox>
    </HBox>

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Tìm theo tên đọc giả, tên sách..."
                   styleClass="search-field" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="paidFilter" promptText="Tất cả" prefWidth="160"/>
    </HBox>

    <!-- Date range row -->
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Label text="Từ ngày:" style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        <DatePicker fx:id="fromDatePicker" prefWidth="130"/>
        <Label text="Đến ngày:" style="-fx-font-size:12px; -fx-text-fill:#64748B;"/>
        <DatePicker fx:id="toDatePicker" prefWidth="130"/>
        <Button text="Xóa bộ lọc" styleClass="btn-outline" onAction="#clearDateFilter"
                style="-fx-font-size:11px; -fx-padding:5 12 5 12;"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="fineTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colSTT"        text="STT"           prefWidth="50"/>
            <TableColumn fx:id="colMember"     text="Đọc giả"       prefWidth="180"/>
            <TableColumn fx:id="colBook"       text="Sách"          prefWidth="200"/>
            <TableColumn fx:id="colDueDate"    text="Hạn trả"       prefWidth="100"/>
            <TableColumn fx:id="colReturnDate" text="Ngày trả"      prefWidth="100"/>
            <TableColumn fx:id="colAmount"     text="Số tiền phạt"  prefWidth="120"/>
            <TableColumn fx:id="colReason"     text="Lý do"         prefWidth="200"/>
            <TableColumn fx:id="colPaid"       text="Trạng thái"    prefWidth="110"/>
            <TableColumn fx:id="colActions"    text="Thao tác"      prefWidth="140"/>
        </columns>
        <placeholder><Label text="Không có phí phạt nào"/></placeholder>
    </TableView>

    <!-- Pagination -->
    <HBox alignment="CENTER_LEFT" spacing="8">
        <Label fx:id="statusLabel" text="" style="-fx-text-fill: #64748B; -fx-font-size: 12px;" HBox.hgrow="ALWAYS"/>
        <Button fx:id="prevPageBtn" text="← Trước" styleClass="btn-outline" onAction="#prevPage"/>
        <Label fx:id="pageInfoLabel" text="Trang 1 / 1" style="-fx-font-size: 12px;"/>
        <Button fx:id="nextPageBtn" text="Sau →" styleClass="btn-outline" onAction="#nextPage"/>
    </HBox>
</VBox>
