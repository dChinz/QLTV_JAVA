<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.MemberController"
      spacing="16" styleClass="content-area">

    <!-- Toolbar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Tìm theo tên, mã thẻ, SĐT..."
                   styleClass="search-field" HBox.hgrow="ALWAYS" onAction="#handleSearch"/>
        <ComboBox fx:id="statusFilter" promptText="Tất cả trạng thái" prefWidth="180"
                  onAction="#handleSearch"/>
        <Button text="Tìm kiếm" styleClass="btn-primary" onAction="#handleSearch"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Thêm đọc giả" styleClass="btn-success" onAction="#handleAdd"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="memberTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colCode"    text="Mã thẻ"     prefWidth="80"/>
            <TableColumn fx:id="colName"    text="Họ tên"      prefWidth="180"/>
            <TableColumn fx:id="colPhone"   text="SĐT"         prefWidth="110"/>
            <TableColumn fx:id="colEmail"   text="Email"       prefWidth="180"/>
            <TableColumn fx:id="colExpiry"  text="Hạn thẻ"     prefWidth="100"/>
            <TableColumn fx:id="colStatus"  text="Trạng thái"  prefWidth="100"/>
            <TableColumn fx:id="colActions" text="Thao tác"    prefWidth="220"/>
        </columns>
        <placeholder><Label text="Không tìm thấy đọc giả nào"/></placeholder>
    </TableView>

    <Label fx:id="statusLabel" text="" style="-fx-text-fill: #64748B; -fx-font-size: 12px;"/>
</VBox>
